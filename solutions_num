import numpy as np
import matplotlib.pyplot as plt

def euler_explicite(f, x0, t0, tf, h):
    """
    Résolution de x' = f(t,x)
    par le schéma d'Euler explicite.
    """

    N = int(np.ceil((tf - t0) / h))
    h = (tf - t0) / N

    T = np.zeros(N + 1)
    X = np.zeros(N + 1)

    T[0] = t0
    X[0] = x0

    for n in range(N):
        T[n + 1] = T[n] + h
        X[n + 1] = X[n] + h * f(T[n], X[n])

    return T, X


