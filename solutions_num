# Courbe de convergence

H = np.logspace(0, -5, 20)
E = np.zeros(len(H))

for i, h in enumerate(H):
    T, X = euler_explicite(f_stable, 1, 0, 3, h)
    E[i] = np.max(np.abs(solution_stable(T) - X))

